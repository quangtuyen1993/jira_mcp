# Jira Server URL
JIRA_BASE_URL=https://jira.pnj.com.vn

# --- Chọn 1 trong 2 cách xác thực bên dưới ---

# Cách 1: Basic Auth (username + password/token)
JIRA_AUTH_TYPE=basic
JIRA_USERNAME=your-username
JIRA_PASSWORD=your-password-or-api-token

# Cách 2: Session Auth (login qua API để lấy JSESSIONID)
# JIRA_AUTH_TYPE=session
# JIRA_USERNAME=your-username
# JIRA_PASSWORD=your-password
# JIRA_LOGIN_ENDPOINT=/rest/auth/1/session
